package dev.archety.studentmanager.controller;

import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("/api/students")
public class StudentController {

    private final StudentService studentService;

    @Value("${app.name}")
    private String appName;

    @Value("${app.version}")
    private String appVersion;

    @Value("${app.profile}")
    private String appProfile;

    public StudentController(StudentService studentService) {
        this.studentService = studentService;
    }

    @GetMapping
    public List<StudentResponse> findAll() {
        return studentService.findAll();
    }

    @GetMapping("/{id}")
    public StudentResponse findById(@PathVariable Long id) {
        return studentService.findById(id);
    }

    @PostMapping
    public StudentResponse create(@Valid @RequestBody StudentRequest request) {
        return studentService.create(request);
    }

    @PutMapping("/{id}")
    public StudentResponse update(@PathVariable Long id, @Valid @RequestBody StudentRequest request) {
        return studentService.update(id, request);
    }

    @PatchMapping("/{id}/status")
    public StudentResponse updateStatus(@PathVariable Long id,
                                        @Valid @RequestBody StudentStatusUpdateRequest request) {
        return studentService.updateStatus(id, request);
    }

    @DeleteMapping("/{id}")
    public Map<String, String> delete(@PathVariable Long id) {
        studentService.delete(id);
        return Map.of("message", "Student with id " + id + " deleted successfully");
    }

    @GetMapping("/search")
    public List<StudentResponse> search(@RequestParam(required = false) String course,
                                        @RequestParam(required = false) StudentStatus status) {
        return studentService.search(course, status);
    }

    @GetMapping("/count")
    public Map<String, Long> count() {
        return Map.of("count", studentService.count());
    }

    @GetMapping("/seed-info")
    public Map<String, Object> seedInfo() {
        Map<String, Object> response = new LinkedHashMap<>();
        response.put("message", "Sample student data loaded in memory");
        response.put("count", studentService.count());
        return response;
    }

    @GetMapping("/ping")
    public Map<String, String> ping() {
        return Map.of("message", "Student Manager API is running");
    }

    @GetMapping("/version")
    public VersionResponse version() {
        return new VersionResponse(appName, appVersion, appProfile);
    }
}